PORT=3000

# Gmail SMTP credentials
# SMTP_USER must be a full Gmail address.
# SMTP_PASS must be a Google App Password (NOT your Gmail login password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Default "from" header for outgoing email
MAIL_FROM="Dishi Software <your-email@gmail.com>"

# Inbox that receives contact form submissions
MAIL_TO=your-email@gmail.com

# Comma-separated list of frontend origins allowed to call this API.
# Local dev (Vite, CRA): http://localhost:5173,http://localhost:3000
# Production: https://dishisoftware.com,https://www.dishisoftware.com
CORS_ORIGINS=http://localhost:5173
